---
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
const logo = (slug: string) => `${stripBase(base)}/logos/${slug}.svg`;

const logos = [
  { slug: 'meta', alt: 'Meta' },
  { slug: 'netflix', alt: 'Netflix' },
  { slug: 'spotify', alt: 'Spotify' },
  { slug: 'nbc', alt: 'NBC' },
  { slug: 'universal', alt: 'Universal Music Group' },
  { slug: 'warner', alt: 'Warner Music Group' },
];
---
<section data-component="WorkTeaser" data-animate="fade-up" data-cycle="logos" class="py-12 md:py-16 border-t border-rule">
  <div class="flex items-baseline justify-between mb-6 md:mb-8">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Selected Work</h2>
    <a
      href={`${stripBase(base)}/work`}
      class="text-sm text-navy hover:text-amber border-b border-current"
    >See selected work &rarr;</a>
  </div>

  <div class="flex flex-wrap items-center gap-x-10 gap-y-6 mb-6">
    {logos.map((l) => (
      <img
        src={logo(l.slug)}
        alt={l.alt}
        class="logo-mono h-10 md:h-12 w-auto max-w-[240px]"
        loading="lazy"
      />
    ))}
  </div>

  <p class="text-lg text-muted max-w-3xl">
    <span data-animate="counter" data-count-to="26">26</span> years of shipping software for companies that need it to last. Logos above are the recognizable ones.
  </p>
</section>
