---
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
---
<section data-component="AboutTeaser">
  <h2>Who I am</h2>

  <p>Christian first. Entrepreneur second. I run Bossa Nova Solutions, building products across six industries and counting.</p>
  <p>Tuesday Notes goes out weekly. Faith, tech, golf, and what I'm building.</p>

  <p><a href={`${stripBase(base)}/about`}>More about me &rarr;</a></p>
</section>
