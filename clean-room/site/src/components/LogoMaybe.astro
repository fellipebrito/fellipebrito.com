---
// Renders <img> if a logo file exists at /public/logos/<slug>.<ext>.
// Renders nothing if the slug isn't in AVAILABLE_LOGOS.
// Add a slug + extension here once its file ships in public/logos/.
const AVAILABLE_LOGOS: Record<string, string> = {
  meta: 'svg',
  netflix: 'svg',
  spotify: 'svg',
  nbc: 'svg',
  universal: 'svg',
  warner: 'svg',
  sesac: 'svg',
  ping: 'png',
  qwire: 'png',
  rumblefish: 'png',
  'whiskey-social': 'png',
  uvl: 'png',
};

interface Props {
  slug: string;
  alt: string;
  class?: string;
}
const { slug, alt, class: cls = 'h-6' } = Astro.props;

const ext = AVAILABLE_LOGOS[slug];
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
const url = ext ? `${stripBase(base)}/logos/${slug}.${ext}` : null;
---
{url && (
  <img
    src={url}
    alt={alt}
    class={`logo-mono ${cls}`}
    loading="lazy"
  />
)}
