---
import BlogCard from './BlogCard.astro';
import articlesData from '../data/articles.json';

const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);

// Latest 3 dated articles, newest first.
const dated = articlesData.articles.filter((a) => a.date !== null);
dated.sort((a, b) => (a.date! < b.date! ? 1 : -1));
const latest = dated.slice(0, 3);
---
<section data-component="WritingTeaser">
  <h2>Recent writing</h2>
  <div class="card-grid">
    {latest.map((a) => (
      <BlogCard
        title={a.title}
        slug={a.slug}
        date={a.date}
        category={a.category}
      />
    ))}
  </div>
  <p><a href={`${stripBase(base)}/blog/all`}>View all writing &rarr;</a></p>
</section>
