---
import GlobalHeader from '../components/GlobalHeader.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- IBM Plex Sans + Mono via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <GlobalHeader />
    <main class="flex-1 w-full max-w-[var(--container-wide)] mx-auto px-5 md:px-8 py-8 md:py-12">
      <slot />
    </main>
    <GlobalFooter />

    <!-- Scroll animations — vanilla IntersectionObserver, no library.
         Pattern: JS hides then reveals (NOT CSS hides). Multiple safety nets:
         try/catch, prefers-reduced-motion bailout, 3s force-reveal timeout.
         If ANYTHING fails, content stays visible. -->
    <script is:inline>
      (function () {
        if (!('IntersectionObserver' in window)) return;
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        try {
          var els = document.querySelectorAll('[data-animate="fade-up"]');
          if (!els.length) return;

          var observer = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
                observer.unobserve(entry.target);
              }
            });
          }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });

          els.forEach(function (el) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(20px)';
            el.style.transition = 'opacity 600ms cubic-bezier(0.16, 1, 0.3, 1), transform 600ms cubic-bezier(0.16, 1, 0.3, 1)';
            observer.observe(el);
          });

          // Safety net: force-reveal anything still hidden after 3s.
          setTimeout(function () {
            els.forEach(function (el) {
              if (el.style.opacity === '0') {
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
              }
            });
          }, 3000);
        } catch (e) {
          // Any error → force-reveal everything.
          document.querySelectorAll('[data-animate="fade-up"]').forEach(function (el) {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          });
        }
      })();
    </script>
  </body>
</html>
