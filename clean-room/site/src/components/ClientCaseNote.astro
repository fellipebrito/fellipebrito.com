---
import LogoMaybe from './LogoMaybe.astro';

interface Props {
  name: string;
  slug: string;
  caseNote?: string;
  displayOnly?: 'logo' | 'card';
}
const { name, slug, caseNote, displayOnly = 'card' } = Astro.props;

const isPlaceholder = caseNote?.startsWith('NEEDS REVIEW') ?? false;
const paragraphs = caseNote && !isPlaceholder
  ? caseNote.split('\n\n').filter((p) => p.trim().length > 0)
  : [];
---
{displayOnly === 'logo' ? (
  <article
    data-component="ClientCaseNote"
    id={`client-${slug}`}
    data-display="logo"
    class="py-8 px-4 border border-rule rounded-md flex items-center justify-center text-center bg-bg min-h-[88px]"
  >
    <LogoMaybe slug={slug} alt={name} class="max-h-8 w-auto max-w-[120px]" />
    <span class="sr-only">{name}</span>
  </article>
) : (
  <article
    data-component="ClientCaseNote"
    id={`client-${slug}`}
    data-display="card"
    class="p-6 md:p-7 border border-rule rounded-md bg-bg"
  >
    <div class="flex items-center justify-between gap-4 mb-3 flex-wrap">
      <h3 class="text-xl md:text-2xl font-semibold tracking-tight">
        {name}
      </h3>
      <LogoMaybe slug={slug} alt={name} class="h-6 max-w-[100px] w-auto" />
    </div>
    {isPlaceholder ? (
      <p class="needs-review">{caseNote}</p>
    ) : (
      paragraphs.map((p) => (
        <p class="text-base leading-relaxed text-ink mb-3 last:mb-0">{p}</p>
      ))
    )}
  </article>
)}
