---
// BlogCard — used in writing indexes and the home WritingTeaser.
// Date sourced from articles.json `date` field (NOT the listing UI's "July 25, 2023" Framer placeholder).
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);

interface Props {
  title: string;
  slug: string;
  date: string | null;
  category: string;
}
const { title, slug, date, category } = Astro.props;
const href = `${stripBase(base)}/blog/all/${slug}`;
---
<article data-component="BlogCard" class="group">
  <p class="text-xs uppercase tracking-wider text-amber font-medium mb-2">
    {category}
  </p>
  <h3 class="text-lg md:text-xl font-semibold leading-tight mb-2">
    <a href={href} class="text-ink hover:text-navy">
      {title}
    </a>
  </h3>
  {date
    ? <p class="text-sm text-muted"><time datetime={date}>{date}</time></p>
    : <p class="needs-review">NEEDS REVIEW: date TBD</p>}
</article>
