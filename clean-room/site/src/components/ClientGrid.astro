---
import clientsData from '../data/clients.json';
import ClientCaseNote from './ClientCaseNote.astro';

interface Props {
  phase?: 'past' | 'current';
}
const { phase } = Astro.props;
const clients = phase
  ? clientsData.clients.filter((c) => c.phase === phase)
  : clientsData.clients;
const displayOnly = phase === 'past' ? 'logo' : 'card';
---
<section data-component="ClientGrid" data-phase={phase}>
  <div
    data-animate="stagger"
    class:list={[
      'grid gap-4',
      displayOnly === 'logo'
        ? 'grid-cols-2 sm:grid-cols-3 md:grid-cols-5'
        : 'grid-cols-1 md:grid-cols-2 gap-6',
    ]}
  >
    {clients.map((c) => (
      <ClientCaseNote name={c.name} slug={c.slug} caseNote={c.case_note} displayOnly={displayOnly} />
    ))}
  </div>
</section>
