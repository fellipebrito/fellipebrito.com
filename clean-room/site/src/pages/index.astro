---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBlock from '../components/HeroBlock.astro';
import WritingTeaser from '../components/WritingTeaser.astro';
import WorkTeaser from '../components/WorkTeaser.astro';
import AboutTeaser from '../components/AboutTeaser.astro';

const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
---
<BaseLayout
  title="Fellipe Brito — Christian. Entrepreneur. Creative problem solver."
  description="Founder of Bossa Nova Solutions. Past lives at Facebook and SESAC. Now building for PING, QWIRE, UVL, and a few others. 26 years shipping software. Tuesday Notes weekly."
>
  <HeroBlock
    variant="home"
    h1={`Christian. Entrepreneur.\nCreative problem solver.`}
    supporting="<mark>Bossa Nova Solutions</mark>. Past lives at <mark>Facebook</mark> and <mark>SESAC</mark>. Currently building solutions for <mark>PING</mark>, <mark>QWIRE</mark>, <mark>UVL</mark>, and a few others."
    primaryCtaHref={`${stripBase(base)}/hire`}
    primaryCtaText="Work with me"
  />
  <WritingTeaser />
  <WorkTeaser />
  <AboutTeaser />
</BaseLayout>
