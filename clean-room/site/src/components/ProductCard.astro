---
import LogoMaybe from './LogoMaybe.astro';

interface ProductLinks {
  ios?: string | null;
  android?: string | null;
}
interface Props {
  name: string;
  slug: string;
  links?: ProductLinks;
  blurb: string;
}
const { name, slug, links, blurb } = Astro.props;
const isPlaceholder = blurb.startsWith('NEEDS REVIEW');
const ios = links?.ios;
const android = links?.android;
---
<article
  data-component="ProductCard"
  id={`product-${slug}`}
  class="p-6 md:p-7 border border-rule rounded-md bg-bg flex flex-col"
>
  <div class="flex items-center gap-4 mb-3">
    <LogoMaybe slug={slug} alt={`${name} app icon`} class="w-12 h-12 rounded-lg flex-shrink-0" />
    <h3 class="text-xl md:text-2xl font-semibold tracking-tight">{name}</h3>
  </div>
  {isPlaceholder
    ? <p class="needs-review">{blurb}</p>
    : <p class="text-base leading-relaxed text-ink mb-4 flex-1">{blurb}</p>}
  {(ios || android) && (
    <p class="text-sm text-muted mt-auto pt-2 border-t border-rule">
      {ios && (
        <a href={ios} class="text-navy hover:text-amber border-b border-current">App Store</a>
      )}
      {ios && android && <span class="mx-2">&middot;</span>}
      {android && (
        <a href={android} class="text-navy hover:text-amber border-b border-current">Google Play</a>
      )}
    </p>
  )}
</article>
