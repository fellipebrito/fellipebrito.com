---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBlock from '../components/HeroBlock.astro';
import ContactBlock from '../components/ContactBlock.astro';
import TestimonialQuote from '../components/TestimonialQuote.astro';
---
<BaseLayout
  title="Work with me — Fellipe Brito"
  description="Tell me what you're building. Software for companies that need it to last. Bossa Nova Solutions — embedded teams, hard problems, no fluff."
>
  <HeroBlock variant="page-default" h1="Work with me" />

  <section data-component="HireTestimonial" data-animate="fade-up" class="py-8">
    <TestimonialQuote
      author="Sam Kling"
      role="Chief Creative Officer, SESAC"
      logoSlug="sesac"
      showRecommendationsLink={true}
    >
      <p>"In a world of probabilities, where circumstances often predetermine outcomes, Fellipe Brito is an absolute improbability."</p>
    </TestimonialQuote>
  </section>

  <section data-animate="fade-up" class="py-8 border-t border-rule">
    <ContactBlock />
  </section>
</BaseLayout>
