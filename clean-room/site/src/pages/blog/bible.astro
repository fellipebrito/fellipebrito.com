---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBlock from '../../components/HeroBlock.astro';
import BlogList from '../../components/BlogList.astro';
import NewsletterInline from '../../components/NewsletterInline.astro';
import articlesData from '../../data/articles.json';

const articles = articlesData.articles
  .filter((a) => a.category === 'Bible')
  .sort((a, b) => {
    if (!a.date && !b.date) return 0;
    if (!a.date) return 1;
    if (!b.date) return -1;
    return a.date < b.date ? 1 : -1;
  });
---
<BaseLayout
  title="Bible — Fellipe Brito"
  description="Writing on the Bible. Ancient words. Present meaning. Eternal hope. Not to master it — to be shaped by it."
>
  <HeroBlock
    variant="page-default"
    h1="Ancient words. Present meaning. Eternal hope."
    supporting="I explore the Bible not to master it, but to be shaped by it."
  />
  <BlogList articles={articles} />
  <NewsletterInline
    heading="Get the Tuesday Notes"
    copy="Tuesday Notes — written Mondays, sent Tuesdays."
  />
</BaseLayout>
