---
import GlobalHeader from '../components/GlobalHeader.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- IBM Plex Sans + Mono via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <GlobalHeader />
    <main class="flex-1 w-full max-w-[var(--container-wide)] mx-auto px-5 md:px-8 py-8 md:py-12">
      <slot />
    </main>
    <GlobalFooter />

    <!-- Scroll animations via Motion. Four effects, all opt-in via
         data-animate attributes. JS-hides-then-reveals + safety nets. -->
    <script>
      import { animate, inView } from 'motion';

      const reduced =
        window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!reduced) {
        try {
          const EASE = [0.16, 1, 0.3, 1];

          // -------- fade-up --------
          document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
            el.style.opacity = '0';
            el.style.transform = 'translateY(24px)';
          });
          inView('[data-animate="fade-up"]', (target) => {
            animate(target, { opacity: [0, 1], y: [24, 0] }, { duration: 1.4, ease: EASE });
          });

          // -------- stagger (children of container animate in sequence) --------
          document.querySelectorAll('[data-animate="stagger"]').forEach((container) => {
            Array.from(container.children).forEach((child) => {
              child.style.opacity = '0';
              child.style.transform = 'translateY(24px)';
            });
          });
          inView('[data-animate="stagger"]', (target) => {
            Array.from(target.children).forEach((child, i) => {
              animate(
                child,
                { opacity: [0, 1], y: [24, 0] },
                { duration: 1.2, delay: i * 0.16, ease: EASE }
              );
            });
          });

          // -------- mask reveal (clip-path slides off, exposing content) --------
          document.querySelectorAll('[data-animate="mask"]').forEach((el) => {
            el.style.clipPath = 'inset(0 100% 0 0)';
          });
          inView('[data-animate="mask"]', (target) => {
            animate(
              target,
              { clipPath: ['inset(0 100% 0 0)', 'inset(0 0 0 0)'] },
              { duration: 1.8, ease: EASE }
            );
          });

          // -------- logo cycle (gray → original color → gray, repeats 5x, sequenced) --------
          inView('[data-cycle="logos"]', (target) => {
            const logos = target.querySelectorAll('.logo-mono');
            logos.forEach((logo, i) => {
              const controls = animate(
                logo,
                {
                  filter: [
                    'grayscale(100%) contrast(105%)',
                    'grayscale(0%) contrast(105%)',
                    'grayscale(100%) contrast(105%)',
                  ],
                  opacity: [0.7, 1, 0.7],
                },
                {
                  duration: 2.4,
                  delay: i * 0.6,
                  repeat: 4,           // 1 + 4 = 5 total iterations per logo
                  times: [0, 0.5, 1],
                  ease: EASE,
                }
              );
              // After cycle finishes, clear inline styles so :hover CSS
              // (filter override) can take over
              if (controls && controls.then) {
                controls.then(() => {
                  logo.style.filter = '';
                  logo.style.opacity = '';
                }).catch(() => {});
              }
            });
          });

          // -------- counter (number ticks up to data-count-to) --------
          inView('[data-animate="counter"]', (target) => {
            const to = parseInt(target.dataset.countTo || '0', 10);
            if (Number.isNaN(to)) return;
            animate(0, to, {
              duration: 3.0,
              ease: EASE,
              onUpdate: (v) => { target.textContent = Math.round(v).toString(); },
            });
          });

          // -------- highlight pen (sequential — one mark at a time) --------
          // Initial state: 0% width (invisible). CSS transition handles the
          // sweep when JS sets size to 100% via inView. Wave-based stagger:
          // marks that enter viewport within 1.5s of each other are queued
          // and drawn in sequence (600ms between starts). After 1.5s of
          // no new entries, the next wave starts fresh.
          document.querySelectorAll('mark, .highlight').forEach((el) => {
            el.style.backgroundSize = '0% 100%';
            el.style.transition = 'background-size 800ms cubic-bezier(0.16, 1, 0.3, 1)';
          });
          let highlightWaveStart = 0;
          let highlightWaveIndex = 0;
          inView('mark, .highlight', (target) => {
            const now = performance.now();
            if (now - highlightWaveStart > 1500) {
              highlightWaveStart = now;
              highlightWaveIndex = 0;
            }
            const delay = highlightWaveIndex * 600;
            highlightWaveIndex++;
            setTimeout(() => {
              target.style.backgroundSize = '100% 100%';
            }, delay);
          });

          // -------- safety net (force-reveal anything still hidden after 3s) --------
          setTimeout(() => {
            document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
              if (el.style.opacity === '0') {
                el.style.opacity = '1';
                el.style.transform = 'translateY(0)';
              }
            });
            document.querySelectorAll('[data-animate="stagger"]').forEach((container) => {
              Array.from(container.children).forEach((el) => {
                if (el.style.opacity === '0') {
                  el.style.opacity = '1';
                  el.style.transform = 'translateY(0)';
                }
              });
            });
            document.querySelectorAll('[data-animate="mask"]').forEach((el) => {
              if (el.style.clipPath && el.style.clipPath.includes('100%')) {
                el.style.clipPath = 'inset(0 0 0 0)';
              }
            });
            document.querySelectorAll('mark, .highlight').forEach((el) => {
              if (el.style.backgroundSize === '0% 100%') {
                el.style.backgroundSize = '100% 100%';
              }
            });
          }, 3000);
        } catch (e) {
          // Any error → force-reveal everything.
          document.querySelectorAll('[data-animate]').forEach((el) => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            el.style.clipPath = 'inset(0 0 0 0)';
            Array.from(el.children).forEach((child) => {
              child.style.opacity = '1';
              child.style.transform = 'translateY(0)';
            });
          });
        }
      }
    </script>
  </body>
</html>
