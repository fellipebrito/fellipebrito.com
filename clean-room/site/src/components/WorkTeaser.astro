---
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
---
<section data-component="WorkTeaser" class="py-12 md:py-16 border-t border-rule">
  <div class="flex items-baseline justify-between mb-6 md:mb-8">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Selected Work</h2>
    <a
      href={`${stripBase(base)}/work`}
      class="text-sm text-navy hover:text-amber border-b border-current"
    >See selected work &rarr;</a>
  </div>

  <p class="logo-strip mb-4">
    <span>Meta</span>
    <span>&middot; Netflix</span>
    <span>&middot; Spotify</span>
    <span>&middot; NBC</span>
    <span>&middot; Universal</span>
    <span>&middot; Warner</span>
  </p>

  <p class="text-lg text-muted max-w-3xl">
    26 years of shipping software for companies that need it to last. Logos above are the recognizable ones.
  </p>
</section>
