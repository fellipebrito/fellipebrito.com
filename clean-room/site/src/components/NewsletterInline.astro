---
import NewsletterForm from './NewsletterForm.astro';
interface Props {
  heading?: string;
  copy?: string;
}
const {
  heading = 'Like this? More on Tuesdays.',
  copy = 'Faith, tech, golf, and what I\'m building. Written Mondays. Sent Tuesdays.',
} = Astro.props;
---
<section data-component="NewsletterInline" class="py-12 border-t border-rule">
  <div class="max-w-xl">
    <h2 class="text-xl md:text-2xl font-semibold tracking-tight mb-2">{heading}</h2>
    <p class="text-base text-muted mb-5">{copy}</p>
    <NewsletterForm variant="inline" />
  </div>
</section>
