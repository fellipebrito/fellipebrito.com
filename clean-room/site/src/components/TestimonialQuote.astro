---
import LogoMaybe from './LogoMaybe.astro';

interface Props {
  author: string;
  role: string;
  logoSlug?: string;
  showRecommendationsLink?: boolean;
}
const { author, role, logoSlug, showRecommendationsLink = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
---
<blockquote data-component="TestimonialQuote" class="max-w-3xl">
  <slot />
  <footer class="flex items-center gap-3 flex-wrap">
    {logoSlug && <LogoMaybe slug={logoSlug} alt={role} class="h-5 max-w-[80px] w-auto" />}
    <span>&mdash; {author}, {role}</span>
  </footer>
  {showRecommendationsLink && (
    <p class="recommendations-link">
      <a href={`${stripBase(base)}/recommendations`}>more recommendations &rarr;</a>
    </p>
  )}
</blockquote>
