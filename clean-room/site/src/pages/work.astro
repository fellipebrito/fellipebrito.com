---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroBlock from '../components/HeroBlock.astro';
import WorkRow from '../components/WorkRow.astro';
import ClientGrid from '../components/ClientGrid.astro';
import ProductGrid from '../components/ProductGrid.astro';
import TestimonialQuote from '../components/TestimonialQuote.astro';
---
<BaseLayout title="Selected Work — Fellipe Brito">
  <HeroBlock variant="page-default" h1="Selected Work" />

  <!-- Bio -->
  <section data-component="WorkBio" data-animate="fade-up" class="max-w-3xl pb-8">
    <p class="text-xl md:text-2xl leading-snug font-medium">
      Christian. Entrepreneur. Creative problem solver.
    </p>
    <p class="text-lg text-muted mt-3">
      I run Bossa Nova Solutions. The work below is the receipts.
    </p>
  </section>

  <section data-component="WhereEmbedded" data-animate="fade-up" class="py-12 border-t border-rule">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-1">Where I've been embedded</h2>
    <p class="text-base text-muted italic mb-6">On payroll. Shipped product alongside their teams.</p>

    <WorkRow company="Meta" logoSlug="meta" years="2018–2022">
      <p>Tech Solutions Architect, Media Operations. Music licensing across Facebook, Instagram, WhatsApp. <mark>3-time Meta Hackathon winner</mark> (Quest, Messenger).</p>
    </WorkRow>

    <WorkRow company="SESAC" logoSlug="sesac" years="2014–2018">
      <p>Director of Engineering. Rebuilt the royalty payment system end to end <mark>(3 months &rarr; 1 week, releasing tens of millions in back-pay to artists)</mark>. Built part of the dev team that still serves SESAC, Rumblefish, and MLC today.</p>
    </WorkRow>

    <WorkRow company="Rumblefish" logoSlug="rumblefish" years="2013–2014">
      <p>Music licensing tech under the SESAC/HFA umbrella. Tools for independent publishers.</p>
    </WorkRow>
  </section>

  <section data-component="ShippedFor" data-animate="fade-up" data-cycle="logos" class="py-12 border-t border-rule">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-1">Shipped for</h2>
    <p class="text-base text-muted italic mb-6">Project work. Delivered. Moved on.</p>
    <ClientGrid phase="past" />
  </section>

  <section data-component="CurrentlyBuildingWith" data-animate="fade-up" class="py-12 border-t border-rule">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-1">Currently building with</h2>
    <p class="text-base text-muted italic mb-6">Active partnerships. Ongoing work.</p>
    <ClientGrid phase="current" />
  </section>

  <section data-component="MyProducts" data-animate="fade-up" class="py-12 border-t border-rule">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-1">My products</h2>
    <p class="text-base text-muted italic mb-6">Things I'm building under my own roof.</p>
    <ProductGrid />
  </section>

  <section data-component="Testimonial" data-animate="fade-up" class="py-12 border-t border-rule">
    <TestimonialQuote
      author="Muhammad Qasim"
      role="CIO at SESAC"
      logoSlug="sesac"
      showRecommendationsLink={true}
    >
      <p>"Hard to distinguish the Bossa Nova team members from our own employees."</p>
    </TestimonialQuote>
  </section>
</BaseLayout>
