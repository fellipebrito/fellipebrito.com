---
// HeroBlock — variants:
//   home:         H1 + supporting line + primary CTA button (Work with me)
//   page-default: H1 + optional supporting subhead
//
// Newsletter signup is NOT in the home hero — the footer form is the
// site-wide capture. Hero focuses on the primary action: hire.
interface Props {
  variant?: 'home' | 'page-default';
  h1: string;
  supporting?: string;
  primaryCtaHref?: string;
  primaryCtaText?: string;
}
const {
  variant = 'page-default',
  h1,
  supporting,
  primaryCtaHref,
  primaryCtaText,
} = Astro.props;
---
<section
  data-component="HeroBlock"
  data-variant={variant}
  class:list={[
    'w-full',
    variant === 'home' ? 'py-12 md:py-20' : 'py-8 md:py-12',
  ]}
>
  <h1
    data-animate={variant === 'page-default' ? 'mask' : undefined}
    class:list={[
      'font-semibold tracking-tight text-ink',
      variant === 'home'
        ? 'text-4xl md:text-5xl lg:text-6xl max-w-4xl'
        : 'text-3xl md:text-4xl max-w-3xl',
    ]}
  >
    {h1.split('\n').map((line, i, arr) => (
      <>{line}{i < arr.length - 1 && <br />}</>
    ))}
  </h1>

  {supporting && (
    <p class="text-lg md:text-xl text-muted mt-5 max-w-3xl leading-snug">
      {supporting}
    </p>
  )}

  {variant === 'home' && primaryCtaHref && primaryCtaText && (
    <div class="mt-10">
      <a
        href={primaryCtaHref}
        class="inline-block px-6 py-3 text-base md:text-lg font-medium text-bg bg-navy hover:bg-navy-hover rounded-sm transition-colors"
      >
        {primaryCtaText}
      </a>
    </div>
  )}
</section>
