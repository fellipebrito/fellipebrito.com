---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBlock from '../../components/HeroBlock.astro';
import BlogList from '../../components/BlogList.astro';
import articlesData from '../../data/articles.json';

const articles = articlesData.articles
  .filter((a) => a.category === 'Music')
  .sort((a, b) => {
    if (!a.date && !b.date) return 0;
    if (!a.date) return 1;
    if (!b.date) return -1;
    return a.date < b.date ? 1 : -1;
  });
---
<BaseLayout
  title="Music — Fellipe Brito"
  description="Writing on lyrics and the songs that move me. Like the Psalms — questions, prayers, glimpses of beauty in a broken world."
>
  <HeroBlock
    variant="page-default"
    h1="Like the Psalms"
    supporting="Exploring lyrics that move me—songs that echo questions, prayers, and glimpses of beauty in a broken world."
  />
  <BlogList articles={articles} />
</BaseLayout>
