---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBlock from '../../components/HeroBlock.astro';
import BlogList from '../../components/BlogList.astro';
import articlesData from '../../data/articles.json';

const articles = articlesData.articles
  .filter((a) => a.category === 'Golf')
  .sort((a, b) => {
    if (!a.date && !b.date) return 0;
    if (!a.date) return 1;
    if (!b.date) return -1;
    return a.date < b.date ? 1 : -1;
  });
---
<BaseLayout
  title="Golf — Fellipe Brito"
  description="Writing on golf. Patience, presence, humility — and the mental side of chasing a little white ball around."
>
  <HeroBlock
    variant="page-default"
    h1="Golf is where I learn patience, presence, and humility."
    supporting="Beyond swing mechanics into the mental, emotional, and spiritual side of chasing a little white ball around."
  />
  <BlogList articles={articles} />
</BaseLayout>
