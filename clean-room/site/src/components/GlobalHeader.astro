---
// GlobalHeader — sitewide nav (v2 IA).
// Brand wordmark on the left, four nav links on the right.
const base = import.meta.env.BASE_URL;
const href = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
---
<header data-component="GlobalHeader">
  <a class="wordmark" href={href('/')}>Fellipe Brito</a>
  <nav>
    <ul>
      <li><a href={href('/blog/all')}>Writing</a></li>
      <li><a href={href('/work')}>Work</a></li>
      <li><a href={href('/about')}>About</a></li>
      <li><a href={href('/hire')}>Hire</a></li>
    </ul>
  </nav>
</header>
