---
import NewsletterForm from './NewsletterForm.astro';
const base = import.meta.env.BASE_URL;
const href = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
const year = new Date().getFullYear();
---
<footer data-component="GlobalFooter">
  <p><strong>Fellipe Brito</strong></p>

  <NewsletterForm variant="footer" />

  <nav>
    <ul>
      <li><a href={href('/blog/all')}>Writing</a></li>
      <li><a href={href('/work')}>Work</a></li>
      <li><a href={href('/about')}>About</a></li>
      <li><a href={href('/hire')}>Hire</a></li>
      <li><a href={href('/recommendations')}>Recommendations</a></li>
    </ul>
  </nav>

  <p><small>&copy; {year} Fellipe Brito &middot; Bossa Nova Solutions</small></p>

  <p><small>I refuse to pay my way into not needing people anymore. <a href={href('/blog/all/ai-where-i-m-drawing-the-line')}>Why &rarr;</a></small></p>
</footer>
