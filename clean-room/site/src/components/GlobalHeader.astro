---
// GlobalHeader — sitewide nav (v2 IA).
// Brand wordmark on the left, four nav links on the right.
const base = import.meta.env.BASE_URL;
const href = (p: string) => (base.endsWith('/') ? base.slice(0, -1) : base) + p;
---
<header data-component="GlobalHeader" class="border-b border-rule bg-bg">
  <div class="w-full max-w-[var(--container-wide)] mx-auto px-5 md:px-8 py-4 flex items-center justify-between gap-4 flex-wrap">
    <a
      class="font-semibold text-base md:text-lg tracking-tight text-ink hover:text-navy"
      href={href('/')}
    >
      Fellipe Brito
    </a>
    <nav>
      <ul class="flex gap-5 md:gap-7 text-sm md:text-base">
        <li><a href={href('/blog/all')} class="text-ink hover:text-navy">Writing</a></li>
        <li><a href={href('/work')} class="text-ink hover:text-navy">Work</a></li>
        <li><a href={href('/about')} class="text-ink hover:text-navy">About</a></li>
        <li><a href={href('/hire')} class="text-ink hover:text-navy font-medium">Hire</a></li>
      </ul>
    </nav>
  </div>
</header>
