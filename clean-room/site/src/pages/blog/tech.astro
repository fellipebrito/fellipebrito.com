---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroBlock from '../../components/HeroBlock.astro';
import BlogList from '../../components/BlogList.astro';
import articlesData from '../../data/articles.json';

const articles = articlesData.articles
  .filter((a) => a.category === 'Tech')
  .sort((a, b) => {
    if (!a.date && !b.date) return 0;
    if (!a.date) return 1;
    if (!b.date) return -1;
    return a.date < b.date ? 1 : -1;
  });
---
<BaseLayout
  title="Tech — Fellipe Brito"
  description="Writing on tech. What I'm learning building apps, systems, tools, ideas — trying to make tech a little more human."
>
  <HeroBlock
    variant="page-default"
    h1="I build things for people—apps, systems, tools, ideas."
    supporting="Sharing what I'm learning as a developer and entrepreneur trying to make tech a little more human."
  />
  <BlogList articles={articles} />
</BaseLayout>
