---
interface Props {
  name: string;
  slug: string;
  caseNote?: string;
  displayOnly?: 'logo' | 'card';
}
const { name, slug, caseNote, displayOnly = 'card' } = Astro.props;

const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
const logo = `${stripBase(base)}/logos/${slug}.svg`;

const isPlaceholder = caseNote?.startsWith('NEEDS REVIEW') ?? false;
const paragraphs = caseNote && !isPlaceholder
  ? caseNote.split('\n\n').filter((p) => p.trim().length > 0)
  : [];
---
{displayOnly === 'logo' ? (
  <article
    data-component="ClientCaseNote"
    id={`client-${slug}`}
    data-display="logo"
    class="py-8 px-4 border border-rule rounded-md flex items-center justify-center text-center bg-bg min-h-[88px]"
  >
    <img src={logo} alt={name} class="logo-mono max-h-8 w-auto max-w-[120px]" loading="lazy" />
  </article>
) : (
  <article
    data-component="ClientCaseNote"
    id={`client-${slug}`}
    data-display="card"
    class="p-6 md:p-7 border border-rule rounded-md bg-bg"
  >
    <h3 class="text-xl md:text-2xl font-semibold tracking-tight mb-3">
      {name}
    </h3>
    {isPlaceholder ? (
      <p class="needs-review">{caseNote}</p>
    ) : (
      paragraphs.map((p) => (
        <p class="text-base leading-relaxed text-ink mb-3 last:mb-0">{p}</p>
      ))
    )}
  </article>
)}
