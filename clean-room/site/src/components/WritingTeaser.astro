---
import BlogCard from './BlogCard.astro';
import articlesData from '../data/articles.json';

const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);

const dated = articlesData.articles.filter((a) => a.date !== null);
dated.sort((a, b) => (a.date! < b.date! ? 1 : -1));
const latest = dated.slice(0, 3);
---
<section data-component="WritingTeaser" data-animate="fade-up" class="py-12 md:py-16 border-t border-rule">
  <div class="flex items-baseline justify-between mb-6 md:mb-8">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Recent writing</h2>
    <a
      href={`${stripBase(base)}/blog/all`}
      class="text-sm text-navy hover:text-amber border-b border-current"
    >View all writing &rarr;</a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {latest.map((a) => (
      <BlogCard
        title={a.title}
        slug={a.slug}
        date={a.date}
        category={a.category}
      />
    ))}
  </div>
</section>
