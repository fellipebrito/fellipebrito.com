---
import productsData from '../data/products.json';
import ProductCard from './ProductCard.astro';
const products = productsData.products;
---
<section data-component="ProductGrid">
  <div data-animate="stagger" class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {products.map((p) => (
      <ProductCard name={p.name} slug={p.slug} links={p.links} blurb={p.blurb} />
    ))}
  </div>
</section>
