---
import BaseLayout from '../layouts/BaseLayout.astro';
import WritingTeaser from '../components/WritingTeaser.astro';
import WorkTeaser from '../components/WorkTeaser.astro';
import AboutTeaser from '../components/AboutTeaser.astro';

const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
---
<BaseLayout
  title="Fellipe Brito — Christian. Entrepreneur. Creative problem solver."
  description="Founder of Bossa Nova Solutions. Past lives at Facebook and SESAC. Now building for PING, QWIRE, UVL, and a few others. 26 years shipping software. Tuesday Notes weekly."
>
  <section
    data-component="HeroBlockHome"
    data-variant="home"
    class="grid grid-cols-1 lg:grid-cols-[1fr_360px] xl:grid-cols-[1fr_400px] gap-10 lg:gap-14 items-center py-12 md:py-20"
  >
    <div>
      <h1
        data-animate="mask"
        class="font-semibold tracking-tight text-ink text-4xl md:text-5xl lg:text-6xl max-w-4xl"
      >
        Christian. Entrepreneur.<br />Creative problem solver.
      </h1>
      <p
        class="text-lg md:text-xl text-muted mt-5 max-w-3xl leading-snug"
        set:html={`<mark>Bossa Nova Solutions</mark>. Past lives at <mark>Facebook</mark> and <mark>SESAC</mark>. Currently building solutions for <mark>PING</mark>, <mark>QWIRE</mark>, <mark>UVL</mark>, and a few others.`}
      ></p>
      <div class="mt-10">
        <a
          href={`${stripBase(base)}/hire`}
          class="cta-primary inline-flex items-center gap-2 px-6 py-3 text-base md:text-lg font-medium text-bg bg-navy hover:bg-navy-hover rounded-sm transition-colors"
        >
          <span>Work with me</span>
          <span class="cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
    <div data-animate="fade-up">
      <img
        src="/portrait.jpg"
        alt="Fellipe Brito at Cristo Redentor in Rio de Janeiro, wearing a Brazil number-10 jersey"
        width="960"
        height="1200"
        loading="eager"
        class="w-full max-w-[320px] lg:max-w-none rounded-md border border-rule mx-auto lg:mx-0"
      />
    </div>
  </section>

  <WritingTeaser />
  <WorkTeaser />
  <AboutTeaser />
</BaseLayout>
