---
// HeroBlock — variants:
//   home:         H1 + supporting line + NewsletterForm CTA + secondary text link
//   page-default: H1 + optional subhead
import NewsletterForm from './NewsletterForm.astro';

interface Props {
  variant?: 'home' | 'page-default';
  h1: string;
  supporting?: string;
  microcopy?: string;
  secondaryLinkHref?: string;
  secondaryLinkText?: string;
}
const {
  variant = 'page-default',
  h1,
  supporting,
  microcopy,
  secondaryLinkHref,
  secondaryLinkText,
} = Astro.props;
---
<section
  data-component="HeroBlock"
  data-variant={variant}
  class:list={[
    'w-full',
    variant === 'home' ? 'py-12 md:py-20' : 'py-8 md:py-12',
  ]}
>
  <h1
    class:list={[
      'font-semibold tracking-tight text-ink',
      variant === 'home'
        ? 'text-4xl md:text-5xl lg:text-6xl max-w-4xl'
        : 'text-3xl md:text-4xl max-w-3xl',
    ]}
  >
    {h1.split('\n').map((line, i, arr) => (
      <>{line}{i < arr.length - 1 && <br />}</>
    ))}
  </h1>

  {supporting && (
    <p class="text-lg md:text-xl text-muted mt-5 max-w-3xl leading-snug">
      {supporting}
    </p>
  )}

  {variant === 'home' && (
    <div class="mt-10 max-w-md">
      <NewsletterForm variant="hero" />
      {microcopy && (
        <p class="text-sm text-muted mt-3">{microcopy}</p>
      )}
      {secondaryLinkHref && secondaryLinkText && (
        <p class="mt-6 text-sm">
          <a
            href={secondaryLinkHref}
            class="text-navy hover:text-amber border-b border-current"
          >
            {secondaryLinkText}
          </a>
        </p>
      )}
    </div>
  )}
</section>
