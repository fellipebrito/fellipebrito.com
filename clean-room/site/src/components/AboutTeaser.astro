---
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
---
<section data-component="AboutTeaser" data-animate="fade-up" class="py-12 md:py-16 border-t border-rule">
  <div class="flex items-baseline justify-between mb-6 md:mb-8">
    <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Who I am</h2>
    <a
      href={`${stripBase(base)}/about`}
      class="text-sm text-navy hover:text-amber border-b border-current"
    >More about me &rarr;</a>
  </div>

  <div class="max-w-2xl text-lg leading-relaxed">
    <p>Christian first. Entrepreneur second. I run Bossa Nova Solutions, building products across six industries and counting.</p>
  </div>
</section>
