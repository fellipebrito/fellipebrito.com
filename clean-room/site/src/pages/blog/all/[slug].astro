---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleHero from '../../../components/ArticleHero.astro';
import ArticleNavigation from '../../../components/ArticleNavigation.astro';
import { getEntry } from 'astro:content';
import { autoExcerpt } from '../../../utils/excerpt';

export async function getStaticPaths() {
  const data = (await import('../../../data/articles.json')).default;
  return data.articles.map((a: { slug: string }) => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

interface Article {
  slug: string;
  title: string;
  date: string | null;
  category: string;
  prev_slug: string | null;
  next_slug: string | null;
}
const { article } = Astro.props as { article: Article };
const entry = await getEntry('articles', article.slug);
const { Content } = await entry.render();

const description = entry.data.description ?? autoExcerpt(entry.body, 155);
const publishedTime = entry.data.date
  ? new Date(entry.data.date).toISOString()
  : undefined;
---
<BaseLayout
  title={`${article.title} — Fellipe Brito`}
  description={description}
  type="article"
  publishedTime={publishedTime}
>
  <ArticleHero
    title={article.title}
    date={article.date}
    category={article.category}
    translatedFromPt={entry.data.translated_from_pt}
  />

  <article data-component="ArticleBody" class="prose mx-auto">
    <Content />
  </article>

  <ArticleNavigation slug={article.slug} />
</BaseLayout>
