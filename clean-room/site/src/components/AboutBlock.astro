---
const base = import.meta.env.BASE_URL;
const stripBase = (b: string) => (b.endsWith('/') ? b.slice(0, -1) : b);
const link = (p: string) => `${stripBase(base)}${p}`;
---
<section data-component="AboutBlock" data-animate="fade-up" class="prose">

  <!-- Sub-section 1 — Who I am (lead paragraph, no heading) -->
  <div class="mt-8 first:mt-0">
    <p class="text-xl md:text-2xl leading-snug text-ink">
      I run <mark>Bossa Nova Solutions</mark>, building products across music, social, transportation, golf, faith, and education.
    </p>
    <p class="text-lg text-muted mt-3">Self-taught. Still learning. I write here weekly.</p>
  </div>

  <!-- Sub-section 2 — What I do now -->
  <div class="mt-12">
    <h3>What I do now</h3>
    <p>Most days: building Bossa Nova Solutions. Client work, advisory, and a few products of my own.</p>
    <p>Client work spans music, social, transportation, golf, faith, and education. <mark>Different industries, same job: solve the problem creatively</mark>, ship something that lasts.</p>
  </div>

  <!-- Sub-section 3 — Where I've been -->
  <div class="mt-12">
    <h3>Where I've been</h3>
    <p>Embedded at <mark>Meta</mark>, <mark>SESAC</mark>, <mark>Rumblefish</mark>. Shipped for <mark>Netflix</mark>, <mark>NBC</mark>, <mark>Spotify</mark>, <mark>Universal</mark>, <mark>Warner</mark>. Currently building with <mark>PING</mark>, <mark>QWIRE</mark>, <mark>Whiskey Social</mark>, <mark>UVL</mark>.</p>
    <p>Plus my own products: Tee Time Trainer, Season Seek, Prayer Stones, Koine Quest.</p>
    <p>Long version &rarr; <a href={link('/work')}>see selected work</a>.</p>
  </div>

  <!-- Sub-section 4 — What I write about -->
  <div class="mt-12">
    <h3>What I write about</h3>
    <p>
      Four threads:
      <a href={link('/blog/bible')}>Bible</a>,
      <a href={link('/blog/music')}>Music</a>,
      <a href={link('/blog/tech')}>Tech</a>,
      <a href={link('/blog/golf')}>Golf</a>.
    </p>
    <p><mark>I write what I'd want to read</mark>. Better questions over easier answers. Tuesday Notes goes out weekly. Written Mondays. Sent Tuesdays.</p>
  </div>

  <!-- Sub-section 5 — How to find me -->
  <div class="mt-12">
    <h3>How to find me</h3>
    <p>Pick your channel.</p>
    <ul class="not-prose flex flex-wrap gap-x-5 gap-y-2 text-base">
      <li><a href="https://www.linkedin.com/in/fellipebrito/" rel="me" class="text-navy hover:text-amber border-b border-current">LinkedIn</a></li>
      <li><a href="https://github.com/fellipebrito/NOVA" rel="me" class="text-navy hover:text-amber border-b border-current">GitHub</a></li>
      <li><a href="https://www.instagram.com/fellipeeduardo/" rel="me" class="text-navy hover:text-amber border-b border-current">Instagram</a></li>
      <li><a href="https://soundcloud.com/fellipe-brito" rel="me" class="text-navy hover:text-amber border-b border-current">SoundCloud</a></li>
    </ul>
  </div>

</section>
